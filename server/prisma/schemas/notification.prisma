// Notification module Prisma schema

model EmailNotification {
  id              String   @id @default(uuid())
  
  recipientEmail  String
  subject         String
  template        String
  context         String?  @db.Text
  
  sentAt          DateTime?
  failedReason    String?
  
  createdAt       DateTime @default(now())
}

model SMSNotification {
  id              String   @id @default(uuid())
  
  recipientPhone  String
  message         String   @db.Text
  
  sentAt          DateTime?
  failedReason    String?
  
  createdAt       DateTime @default(now())
}

model Notification {
  id              String   @id @default(uuid())
  
  userEmail       String
  type            NotificationType
  title           String
  message         String   @db.Text
  
  isRead          Boolean  @default(false)
  readAt          DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([userEmail])
  @@index([isRead])
}

enum NotificationType {
  ORDER_PLACED
  ORDER_SHIPPED
  ORDER_DELIVERED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  ACCOUNT_ALERT
}
